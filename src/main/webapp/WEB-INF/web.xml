<?xml version="1.0" encoding="UTF-8"?>

<web-app xmlns="http://xmlns.jcp.org/xml/ns/javaee"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://xmlns.jcp.org/xml/ns/javaee 
         http://xmlns.jcp.org/xml/ns/javaee/web-app_3_1.xsd"
         version="3.1">

    <!-- ================= WELCOME FILE ================= -->
    <welcome-file-list>
        <welcome-file>index.jsp</welcome-file>
    </welcome-file-list>

    <!-- ================= ADD RESERVATION ================= -->
    <servlet>
        <servlet-name>AddReservationServlet</servlet-name>
        <servlet-class>com.servlet.AddReservationServlet</servlet-class>
    </servlet>

    <servlet-mapping>
        <servlet-name>AddReservationServlet</servlet-name>
        <url-pattern>/AddReservationServlet</url-pattern>
    </servlet-mapping>

    <!-- ================= DISPLAY RESERVATIONS ================= -->
    <servlet>
        <servlet-name>DisplayReservationServlet</servlet-name>
        <servlet-class>com.servlet.DisplayReservationServlet</servlet-class>
    </servlet>

    <servlet-mapping>
        <servlet-name>DisplayReservationServlet</servlet-name>
        <url-pattern>/DisplayReservationServlet</url-pattern>
    </servlet-mapping>

    <!-- ================= UPDATE RESERVATION ================= -->
    <servlet>
        <servlet-name>UpdateReservationServlet</servlet-name>
        <servlet-class>com.servlet.UpdateReservationServlet</servlet-class>
    </servlet>

    <servlet-mapping>
        <servlet-name>UpdateReservationServlet</servlet-name>
        <url-pattern>/UpdateReservationServlet</url-pattern>
    </servlet-mapping>

    <!-- ================= DELETE RESERVATION ================= -->
    <servlet>
        <servlet-name>DeleteReservationServlet</servlet-name>
        <servlet-class>com.servlet.DeleteReservationServlet</servlet-class>
    </servlet>

    <servlet-mapping>
        <servlet-name>DeleteReservationServlet</servlet-name>
        <url-pattern>/DeleteReservationServlet</url-pattern>
    </servlet-mapping>

    <!-- ================= REPORT DATE / REVENUE ================= -->
    <servlet>
        <servlet-name>ReportCriteriaServlet</servlet-name>
        <servlet-class>com.servlet.ReportCriteriaServlet</servlet-class>
    </servlet>

    <servlet-mapping>
        <servlet-name>ReportCriteriaServlet</servlet-name>
        <url-pattern>/ReportCriteriaServlet</url-pattern>
    </servlet-mapping>

    <!-- ================= MOST BOOKED ROOMS ================= -->
    <servlet>
        <servlet-name>ReportServlet</servlet-name>
        <servlet-class>com.servlet.ReportServlet</servlet-class>
    </servlet>

    <servlet-mapping>
        <servlet-name>ReportServlet</servlet-name>
        <url-pattern>/ReportServlet</url-pattern>
    </servlet-mapping>

</web-app>